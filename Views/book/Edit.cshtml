@model InterfazdeAdministración_SistemadeLibrería.Models.book

@{
    ViewData["Title"] = "Editar Libro";
}

<div class="page-header">
    <h1 class="page-title">Editar <span>Libro</span></h1>
    <a asp-action="Libros" asp-controller="Book" class="btn-secondary-lib">← Volver</a>
</div>

<div class="form-card">

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-lib alert-danger-lib">Revisa los campos con error antes de continuar.</div>
    }

    <form asp-action="Update" asp-controller="Book" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-group-lib">
            <label class="form-label-lib" asp-for="Title">Título</label>
            <input class="form-control-lib" asp-for="Title" />
            <span asp-validation-for="Title" class="text-danger" style="font-size:0.8rem"></span>
        </div>

        <div class="form-group-lib">
            <label class="form-label-lib" asp-for="Description">Descripción</label>
            <textarea class="form-control-lib" asp-for="Description" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger" style="font-size:0.8rem"></span>
        </div>

        <div class="form-group-lib">
            <label class="form-label-lib" asp-for="Author">Autor</label>
            <input class="form-control-lib" asp-for="Author" />
            <span asp-validation-for="Author" class="text-danger" style="font-size:0.8rem"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="form-group-lib">
                    <label class="form-label-lib" asp-for="genero">Género</label>
                    <input class="form-control-lib" asp-for="genero" />
                    <span asp-validation-for="genero" class="text-danger" style="font-size:0.8rem"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-lib">
                    <label class="form-label-lib" asp-for="publicationYear">Año de publicación</label>
                    <input class="form-control-lib" asp-for="publicationYear" type="number" min="1000" max="@DateTime.Now.Year" />
                    <span asp-validation-for="publicationYear" class="text-danger" style="font-size:0.8rem"></span>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="form-group-lib">
                    <label class="form-label-lib" asp-for="quantity">Cantidad</label>
                    <input class="form-control-lib" asp-for="quantity" type="number" min="0" />
                    <span asp-validation-for="quantity" class="text-danger" style="font-size:0.8rem"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-lib">
                    <label class="form-label-lib" asp-for="stock">Stock disponible</label>
                    <input class="form-control-lib" asp-for="stock" type="number" min="0" />
                    <span asp-validation-for="stock" class="text-danger" style="font-size:0.8rem"></span>
                </div>
            </div>
        </div>

        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn-primary-lib">Guardar cambios</button>
            <a asp-action="Libros" asp-controller="Book" class="btn-secondary-lib">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
