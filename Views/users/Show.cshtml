@model InterfazdeAdministración_SistemadeLibrería.Models.User

@{
    ViewData["Title"] = "Detalle del Usuario";
}

<div class="page-header">
    <h1 class="page-title">Detalle del <span>Usuario</span></h1>
    <a asp-action="Users" asp-controller="User" class="btn-secondary-lib">← Volver</a>
</div>

<div class="form-card">
    <div class="detail-row"><span class="detail-label">ID</span><span class="detail-value">#@Model.Id</span></div>
    <div class="detail-row"><span class="detail-label">Nombre</span><span class="detail-value">@Model.Username</span></div>
    <div class="detail-row"><span class="detail-label">Apellido</span><span class="detail-value">@Model.lastname</span></div>
    <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value">@Model.Email</span></div>
    <div class="detail-row"><span class="detail-label">Teléfono</span><span class="detail-value">@Model.number</span></div>
    <div class="detail-row"><span class="detail-label">Registro</span><span class="detail-value">@Model.dateRegistered.ToString("dd/MM/yyyy HH:mm")</span></div>
    <div class="d-flex gap-3 mt-4">
        <a asp-action="Edit" asp-controller="User" asp-route-id="@Model.Id" class="btn-primary-lib">&#9998; Editar</a>
        <a asp-action="Users" asp-controller="User" class="btn-secondary-lib">Volver</a>
    </div>
</div>

@section Styles {
    <style>
    .detail-row { display:flex; gap:1rem; padding:.75rem 0; border-bottom:1px solid var(--border); align-items:center; }
    .detail-label { font-size:.8rem; font-weight:600; color:var(--text-muted); width:140px; flex-shrink:0; text-transform:uppercase; letter-spacing:.5px; }
    .detail-value { font-size:.95rem; color:var(--text); }
</style>
}