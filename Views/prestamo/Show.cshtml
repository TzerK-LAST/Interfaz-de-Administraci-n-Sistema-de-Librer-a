@model InterfazdeAdministración_SistemadeLibrería.Models.Loan

@{
    ViewData["Title"] = "Detalle del Préstamo";
}

<div class="page-header">
    <h1 class="page-title">Detalle del <span>Préstamo</span></h1>
    <a asp-action="Index" asp-controller="Loan" class="btn-secondary-lib">← Volver</a>
</div>

<div class="form-card">
    <div class="detail-row"><span class="detail-label">ID</span><span class="detail-value">#@Model.Id</span></div>
    <div class="detail-row">
        <span class="detail-label">Usuario</span>
        <span class="detail-value">@(Model.UserId != null ? Model.User.Username + " " + Model.User.lastname : "—")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Libro</span>
        <span class="detail-value">@(Model.Book != null ? Model.Book.Title : "—")</span>
    </div>
    <div class="detail-row"><span class="detail-label">Inicio</span><span class="detail-value">@Model.StartDate.ToString("dd/MM/yyyy HH:mm")</span></div>
    <div class="detail-row">
        <span class="detail-label">Devolución</span>
        <span class="detail-value">@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("dd/MM/yyyy HH:mm") : "Pendiente")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Estado</span>
        <span class="detail-value">
            @if (Model.estado == "Activo")
            {
                <span class="badge-stock-low">@Model.estado</span>
            }
            else
            {
                <span class="badge-stock-ok">@Model.estado</span>
            }
        </span>
    </div>
    <div class="d-flex gap-3 mt-4">
        @if (Model.estado == "Activo")
        {
            <form asp-action="Return" asp-controller="Loan" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-primary-lib">&#10003; Marcar como devuelto</button>
            </form>
        }
        <a asp-action="Index" asp-controller="Loan" class="btn-secondary-lib">Volver</a>
    </div>
</div>

